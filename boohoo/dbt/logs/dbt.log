  create  table
    "boohoo_dwh"."public_odl"."dim_customers__dbt_tmp"
    
    
    
  as (
    ------------------------------------------------------------------------------------------------------------------------
-- odl.dim_customers
-- Unified customer dimension across all Boohoo Group brands (star schema)
------------------------------------------------------------------------------------------------------------------------
WITH all_customers AS (
SELECT * FROM "boohoo_dwh"."public_rdl_boohoo_commerce"."boohoo_customers"
UNION ALL
SELECT * FROM "boohoo_dwh"."public_rdl_boohoo_commerce"."boohoo_man_customers"
UNION ALL
