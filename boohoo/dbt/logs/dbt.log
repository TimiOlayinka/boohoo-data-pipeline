[0m19:43:55.230545 [debug] [Thread-4 (]: On model.boohoo_dwh.fact_daily_sales: /* {"app": "dbt", "dbt_version": "1.11.9", "profile_name": "boohoo_dwh", "target_name": "dev", "node_id": "model.boohoo_dwh.fact_daily_sales"} */

  
    

  create  table
    "boohoo_dwh"."bi"."fact_daily_sales__dbt_tmp"
    
    
    
  as (
    ------------------------------------------------------------------------------------------------------------------------
-- bi.fact_daily_sales
-- Daily sales time series for trend analysis
------------------------------------------------------------------------------------------------------------------------
SELECT
    o.order_date,
    o.brand,
    b.brand_tier,
    o.order_year,
    o.order_month,
    o.order_day_of_week,
    COUNT(*)                            AS order_count,
    SUM(o.total_amount)                 AS daily_revenue,
    SUM(o.net_revenue)                  AS daily_net_revenue,
    ROUND(AVG(o.total_amount), 2)       AS avg_order_value,
    SUM(o.item_count)                   AS items_sold,
    COUNT(DISTINCT o.customer_sk)       AS unique_customers
FROM "boohoo_dwh"."odl"."fact_orders" o
LEFT JOIN "boohoo_dwh"."odl"."map_brand" b ON o.brand = b.brand
GROUP BY 1, 2, 3, 4, 5, 6
  );
